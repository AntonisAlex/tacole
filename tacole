<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gra muzyczna</title>
<style>
body {
  font-family: Arial;
  background:#111;
  color:#fff;
  text-align:center;
  margin:0;
}

.container {
  max-width:800px;
  margin:auto;
  padding:20px;
}

h1 { margin-bottom:10px; }

input {
  width:100%;
  padding:12px;
  font-size:16px;
  border-radius:8px;
  border:none;
}

button {
  width:100%;
  padding:12px;
  margin-top:10px;
  border:none;
  border-radius:8px;
  background:#2ecc71;
  color:#fff;
  font-size:16px;
}

#suggestionsBox {
  background:#222;
  border-radius:8px;
  margin-top:5px;
}

.suggestion {
  padding:10px;
  cursor:pointer;
}
.suggestion:hover { background:#333; }

.table-wrapper {
  overflow-x:auto;
  margin-top:20px;
}

table {
  width:100%;
  border-collapse:collapse;
}

th, td {
  border:1px solid #444;
  padding:10px;
  text-align:center;
}

.album-cell {
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
}

.album-cell img {
  width:40px;
  height:40px;
  border-radius:6px;
}

.green { background:#2ecc71; }
.yellow { background:#f1c40f; color:black; }
.gray { background:#333; }

#popup {
  position:fixed;
  top:50%; left:50%;
  transform:translate(-50%,-50%);
  background:#222;
  padding:20px 30px;
  border-radius:10px;
  display:none;
  z-index:1000;
}

#overlay {
  position:fixed;
  top:0; left:0;
  width:100%; height:100%;
  backdrop-filter: blur(6px);
  background:rgba(0,0,0,0.6);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:2000;
}

#menu {
  background:#222;
  padding:30px;
  border-radius:12px;
}

/* MOBILE */
@media (max-width:600px) {
  th, td { font-size:12px; padding:6px; }
  .album-cell img { width:28px; height:28px; }
  h1 { font-size:20px; }
}
</style>
</head>
<body>

<div id="overlay">
  <div id="menu">
    <h2>Instrukcja</h2>
    <p>Zgadnij piosenkę w 8 próbach.</p>
    <button onclick="startGame('easy')">Łatwy</button>
    <button onclick="startGame('hard')">Trudny</button>
  </div>
</div>

<div class="container">
  <h1>Zgadnij piosenkę</h1>

  <input id="search" placeholder="Wpisz tytuł...">
  <div id="suggestionsBox"></div>
  <button onclick="guessSong()">Zgadnij</button>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Piosenka</th>
          <th>Album</th>
          <th>Nr</th>
          <th>Długość</th>
          <th>Goście</th>
        </tr>
      </thead>
      <tbody id="tableBody"></tbody>
    </table>
  </div>
</div>

<div id="popup"></div>

<script>
let songs = [];
let target;
let attempts = 0;

const albumCovers = {
  'Album 1':'cover1.jpg',
  'Album 2':'cover2.jpg',
  'Album 3':'cover3.jpg'
};

function startGame(mode){
  if(mode==='easy'){
    songs=[
      {title:'Song A',album:'Album 1',year:2010,track:1,length:200,features:'X'},
      {title:'Song B',album:'Album 2',year:2012,track:2,length:210,features:'Y'},
      {title:'Song C',album:'Album 3',year:2015,track:3,length:220,features:'Z'}
    ];
  } else {
    songs=[
      {title:'Song D',album:'Album 1',year:2011,track:4,length:230,features:'A'},
      {title:'Song E',album:'Album 2',year:2013,track:5,length:240,features:'B'},
      {title:'Song F',album:'Album 3',year:2016,track:6,length:250,features:'C'},
      {title:'Song G',album:'Album 1',year:2018,track:7,length:260,features:'D'}
    ];
  }

  songs.forEach(s=>s.cover=albumCovers[s.album]||'default.jpg');

  target=songs[Math.floor(Math.random()*songs.length)];
  document.getElementById('overlay').style.display='none';
}

const input=document.getElementById('search');
const box=document.getElementById('suggestionsBox');

input.addEventListener('input',()=>{
  const q=input.value.toLowerCase(); box.innerHTML='';
  songs.filter(s=>s.title.toLowerCase().includes(q)).slice(0,5).forEach(s=>{
    const d=document.createElement('div');
    d.textContent=s.title;
    d.className='suggestion';
    d.onclick=()=>{input.value=s.title;box.innerHTML='';};
    box.appendChild(d);
  });
});

function color(v,t,d){ if(v===t)return'green'; if(Math.abs(v-t)<=d)return'yellow'; return'gray'; }
function arrow(v,t){ if(v===t)return''; return v<t?'⬆️':'⬇️'; }
function time(s){ return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0'); }

function popup(msg){
  const p=document.getElementById('popup');
  p.textContent=msg;
  p.style.display='block';
  setTimeout(()=>p.style.display='none',5000);
}

function guessSong(){
  if(attempts>=8) return popup('Koniec gry');

  const song=songs.find(s=>s.title===input.value);
  if(!song) return popup('Wybierz z listy');

  attempts++;

  const row=document.createElement('tr');
  row.innerHTML=`
    <td class="${song.title===target.title?'green':'gray'}">${song.title}</td>
    <td class="album-cell ${color(song.year,target.year,1)}">
      <img src="${song.cover}">
      ${song.album} ${arrow(song.year,target.year)}
    </td>
    <td class="${color(song.track,target.track,2)}">${song.track} ${arrow(song.track,target.track)}</td>
    <td class="${color(song.length,target.length,15)}">${time(song.length)} ${arrow(song.length,target.length)}</td>
    <td class="${song.features===target.features?'green':'gray'}">${song.features}</td>
  `;

  document.getElementById('tableBody').appendChild(row);
  input.value='';

  if(song.title===target.title) popup('Wygrałeś!');
  else if(attempts===8) popup('Przegrałeś! '+target.title);
}
</script>

</body>
</html>
